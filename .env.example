# =============================================================================
# ClaudeTracer — environment configuration
# =============================================================================
# Copy to .env and set CLAUDE_DIR to your Claude Code data folder:
#   cp .env.example .env
#
# The directory must contain:  projects/<encoded-path>/<session-id>.jsonl
# Typical location:           ~/.claude

# --- Required: Claude Code data directory ---
CLAUDE_DIR=/home/you/.claude

# --- Enterprise billing (optional) ---
# 1.0 = public list API price | 0.7 = 30% contract discount | 0.696 ≈ 30.4% off
ENTERPRISE_DISCOUNT_MULT=1.0

# --- Cloud / platform pricing (optional) ---
# global | regional | bedrock_regional | vertex_regional
CLOUD_ENDPOINT=global

# --- Server (optional) ---
HOST=0.0.0.0
PORT=8000
